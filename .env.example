# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Optional: restrict slash command registration to a single guild (instant updates)
# Leave blank to register globally (may take up to 1 hour to propagate)
DISCORD_GUILD_ID=

# Express server port
PORT=3000

# Maximum concurrent Minecraft bots
MAX_ACTIVE_BOTS=10

# Cooldown for /join command (seconds)
JOIN_COOLDOWN=30